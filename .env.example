# Required in production (ALLOW_DEV_DEFAULTS=false).
# Must be at least 32 bytes in raw string, hex, or base64 format.
APP_SECRET_KEY=

# Bootstrap admin account on first startup (idempotent).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Local development only. Set true to allow insecure startup without APP_SECRET_KEY.
ALLOW_DEV_DEFAULTS=false
