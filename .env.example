# Production defaults (example only; do not commit real secrets)
APP_ENV=prod
SESSION_SECRET=
DATABASE_URL=sqlite:///./norrviq.db

COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
SESSION_COOKIE_NAME=norrviq_session
SESSION_MAX_AGE_SECONDS=604800

LOG_FORMAT=json
LOG_LEVEL=INFO

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_FILES=50

# Local bootstrap only; keep disabled in prod
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
ALLOW_DEV_DEFAULTS=false
